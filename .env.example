# ── API Keys ──────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_gemini_key_here
OPENAI_API_KEY=your_openai_key_here

# ── AI Provider ───────────────────────────────────────────────────────────────
# Chọn provider mặc định: gemini | openai | openai_compatible | local_http | lightonocr
AI_PROVIDER=lightonocr

# ── OpenAI / Compatible ───────────────────────────────────────────────────────
OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o

# ── LightOnOCR ────────────────────────────────────────────────────────────────
# URL của LightOnOCR API
# Khi chạy qua Docker Compose (profile lightonocr): dùng tên service
LOCAL_HTTP_BASE_URL=http://lightonocr:7861/extract
# Khi chạy local (LightOnOCR chạy riêng trên cùng máy):
# LOCAL_HTTP_BASE_URL=http://localhost:7861/extract

# Timeout (giây) khi gọi LightOnOCR — CPU cần nhiều thời gian hơn
LOCAL_HTTP_TIMEOUT=300
LIGHTONOCR_MAX_TOKENS=4096
LIGHTONOCR_TEMPERATURE=0.2

# Device LightOnOCR dùng khi khởi động cùng docker-compose --profile lightonocr:
#   auto  — GPU nếu có, ngược lại CPU
#   cpu   — Ép CPU
#   gpu   — Ép GPU (cần nvidia-container-toolkit)
LIGHTONOCR_DEVICE=auto
# LIGHTONOCR_DTYPE=auto

# ── API Server ────────────────────────────────────────────────────────────────
# API_PORT=8000
CORS_ALLOW_ORIGINS=*

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
